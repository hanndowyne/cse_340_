<%- include('partials/header') %>

    <main>
        <h1>
            <%= project.title %>
        </h1>

        <p>
            <%= project.description %>
        </p>
        <p>Date: <%= project.date %>
        </p>
        <p>Location: <%= project.location %>
        </p>

        <p>
            Organization:
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <h3>Categories:</h3>
        <ul>
            <% if (categories.length> 0) { %>
                <% categories.forEach(category=> { %>
                    <li>
                        <%= category.category_name %> -
                            <a href="/category/<%= category.category_id %>">View Category</a>
                    </li>
                    <% }) %>
                        <% } else { %>
                            <li>No categories assigned</li>
                            <% } %>
        </ul>

        <a href="/projects">Back to Projects</a>

        <p><a href="/edit-project/<%= project.project_id %>">Edit Project</a></p>
    </main>

    <%- include('partials/footer') %>