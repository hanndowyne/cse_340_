<%- include('partials/header') %>

    <main>
        <h1>
            <%= project.title %>
        </h1>

        <p>
            <%= project.description %>
        </p>
        <p>Date: <%= project.date %>
        </p>
        <p>Location: <%= project.location %>
        </p>

        <p>
            Organization:
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>
        <a href="/category/<%= project.category_id %>">View Category</a>

        <a href="/projects">Back to Projects</a>
    </main>

    <%- include('partials/footer') %>