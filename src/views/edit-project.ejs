<%- include('partials/header') %>

    <main>
        <h1>Edit Project</h1>

        <form action="/edit-project/<%= project.project_id %>" method="POST">
            <div>
                <label for="title">Title</label>
                <input type="text" id="title" name="title" value="<%= project.title %>" maxlength="200" required />
            </div>

            <div>
                <label for="description">Description</label>
                <textarea id="description" name="description" maxlength="1000"
                    required><%= project.description %></textarea>
            </div>

            <div>
                <label for="location">Location</label>
                <input type="text" id="location" name="location" value="<%= project.location %>" maxlength="200"
                    required />
            </div>

            <div>
                <label for="date">Date</label>
                <input type="date" id="date" name="date" value="<%= project.project_date.toISOString().split('T')[0] %>"
                    required />
            </div>

            <div>
                <label for="organization">Organization</label>
                <select id="organization" name="organizationId" required>
                    <% organizations.forEach(org=> { %>
                        <option value="<%= org.id %>" <%=org.id===project.organization_id ? 'selected' : '' %>>
                            <%= org.name %>
                        </option>
                        <% }) %>
                </select>
            </div>

            <button type="submit">Update Project</button>
        </form>

        <a href="/project/<%= project.project_id %>">Back to Project</a>
    </main>

    <%- include('partials/footer') %>