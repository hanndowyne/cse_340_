<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>Service Project Categories</h2>

        <ul>
            <ul>
                <% categories.forEach(category=> { %>
                    <li>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                        </li>
                <% }); %>
            </ul>
        </ul>

    </main>

    <%- include('partials/footer') %>